# ============================================================
# Creator GraphRAG — Environment Configuration
# Copy to .env and fill in your values.
# All values marked REQUIRED must be set before starting.
# ============================================================

# --- App ---
APP_ENV=development          # development | staging | production
APP_NAME=creator-graphrag
APP_VERSION=0.1.0
DEBUG=true                   # false in staging/prod
LOG_LEVEL=INFO

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                # Increase for production (2 * CPU + 1)
CORS_ORIGINS=http://localhost:3000

# --- Database (PostgreSQL) --- REQUIRED
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=creator_graphrag
POSTGRES_USER=cgr_user
POSTGRES_PASSWORD=changeme_required
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis --- REQUIRED
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_URL=redis://localhost:6379/1

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=chunks_multilingual
QDRANT_API_KEY=                # optional; required in cloud deployment

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_required

# --- Object Storage (S3 / MinIO) --- REQUIRED
S3_ENDPOINT_URL=http://localhost:9000    # Remove for AWS S3
S3_BUCKET_BOOKS=creator-books
S3_BUCKET_EXPORTS=creator-exports
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=changeme_required
AWS_REGION=us-east-1

# --- Auth (JWT RS256) --- REQUIRED in production
# Generate keys: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# --- LLM / Embeddings --- REQUIRED
LLM_PROVIDER=openai            # openai | azure
OPENAI_API_KEY=sk-...          # REQUIRED if LLM_PROVIDER=openai
AZURE_OPENAI_ENDPOINT=         # REQUIRED if LLM_PROVIDER=azure
AZURE_OPENAI_API_KEY=          # REQUIRED if LLM_PROVIDER=azure
AZURE_OPENAI_API_VERSION=2024-02-01

LLM_EXTRACTION_MODEL=gpt-4o
LLM_GENERATION_MODEL=gpt-4o
LLM_REPAIR_MODEL=gpt-4o-mini

# --- Embeddings ---
# Qwen3-Embedding-8B via Ollama (default, recommended — #1 MTEB Multilingual)
#   Install Ollama: https://ollama.com  then: ollama pull qwen3-embedding:8b
EMBEDDING_MODEL=qwen3-embedding:8b
EMBEDDING_DIMENSION=4096
OLLAMA_ENDPOINT=http://localhost:11434

# --- Baseten (OpenAI-compatible embedding endpoint) ---
# Optional: highest-priority embedding provider when set.
# Uses the OpenAI-compatible chat completions API hosted on Baseten.
BASETEN_API_KEY=                # your Baseten API key
BASETEN_BASE_URL=https://model-q84l5lgw.api.baseten.co/environments/production/predict

# --- OCR ---
OCR_ENGINE=tesseract           # tesseract | azure_vision | sarvam
TESSERACT_DATA_PATH=/usr/share/tessdata
AZURE_VISION_ENDPOINT=         # REQUIRED if OCR_ENGINE=azure_vision
AZURE_VISION_KEY=              # REQUIRED if OCR_ENGINE=azure_vision
OCR_FALLBACK_CONFIDENCE_THRESHOLD=0.60

# --- Document Intelligence (Sarvam AI) ---
# Used for high-quality OCR of scanned Indic-language books (Marathi, Hindi, etc.)
# Outputs: Markdown (document.md) + per-page JSON metadata
# Obtain a key at: https://www.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# --- Language Detection ---
LANG_DETECT_CONFIDENCE_THRESHOLD=0.80
FASTTEXT_MODEL_PATH=./models/lid.176.ftz

# --- Ingestion Pipeline ---
MAX_BOOK_SIZE_MB=500
MAX_CONCURRENT_JOBS_PER_USER=2
CHUNK_MAX_CHARS=2000
CHUNK_OVERLAP_CHARS=250
SCANNED_PAGE_TEXT_THRESHOLD_CHARS=100
SCANNED_PAGE_RATIO_THRESHOLD=0.30

# --- Rate Limits ---
RATE_LIMIT_GENERATE_PER_HOUR=10
RATE_LIMIT_SEARCH_PER_MINUTE=60
RATE_LIMIT_INGEST_PER_HOUR=5

# --- Observability ---
OTLP_ENDPOINT=http://localhost:4317
ENABLE_OTEL=false              # true in staging/prod

# --- Celery ---
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=7200   # 2 hours in seconds

# --- Upload URL Expiry ---
PRESIGNED_UPLOAD_URL_TTL_MINUTES=15
PRESIGNED_DOWNLOAD_URL_TTL_HOURS=1
EXPORT_DOWNLOAD_URL_TTL_HOURS=24

# --- Reranking Weights ---
RERANK_WEIGHT_VECTOR=0.5
RERANK_WEIGHT_CITATION=0.2
RERANK_WEIGHT_CHUNK_TYPE=0.2
RERANK_WEIGHT_CHAPTER_PROXIMITY=0.1

# --- Citation Enforcement ---
# remove_paragraph | label_interpretation | fail_generation
CITATION_REPAIR_MODE=label_interpretation
